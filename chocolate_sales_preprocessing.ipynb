# Lab 4: Data Quality Assessment & Preprocessing
# ARTI 308 - Machine Learning

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import MinMaxScaler, StandardScaler
from sklearn.decomposition import PCA

sns.set(style='whitegrid')
print(" Libraries imported successfully\n")

#  Task 1: Identify Data Quality Issues 
df = pd.read_csv('Chocolate_Sales.csv')  

print("Shape:", df.shape)
print("\nData Types:\n", df.dtypes)
print("\nMissing Values:\n", df.isna().sum())
print("\nDuplicate Rows:", df.duplicated().sum())
print("\nBasic Statistics:\n", df.describe())

print("\n=== Data Quality Issues Identified ===")
print("1. 'Date' column is object → needs to be datetime")
print("2. 'Amount' column is object (contains $ and commas) → needs to be numeric")
print("3. No missing values in original data")
print("4. Possible outliers in 'Amount' and 'Boxes Shipped'")

#  Data Cleaning 
df['Date'] = pd.to_datetime(df['Date'], dayfirst=True)
df['Amount'] = df['Amount'].replace(r'[\$,]', '', regex=True).astype(float)

print("\n Data cleaned successfully")
print("New data types:\n", df.dtypes)

#  Task 2: Handling Missing Values 
# Create artificial missing values for demonstration
df_missing = df.copy()
df_missing.loc[0:10, 'Amount'] = np.nan

print("\nMissing values after artificial injection:\n", df_missing.isna().sum())

# Strategy: Mean Imputation (best for numerical sales data)
df_clean = df_missing.copy()
df_clean['Amount'].fillna(df_clean['Amount'].mean(), inplace=True)

print("\n Missing values handled using Mean Imputation")
print("Remaining missing values:", df_clean.isna().sum().sum())

# Task 3: Detect & Handle Outliers (IQR) 
Q1 = df_clean['Amount'].quantile(0.25)
Q3 = df_clean['Amount'].quantile(0.75)
IQR = Q3 - Q1

lower_bound = Q1 - 1.5 * IQR
upper_bound = Q3 + 1.5 * IQR

outliers = df_clean[(df_clean['Amount'] < lower_bound) | (df_clean['Amount'] > upper_bound)]
print(f"\nNumber of outliers in Amount column: {len(outliers)}")

# Handle outliers by capping (Winsorization)
df_no_outliers = df_clean.copy()
df_no_outliers['Amount'] = df_no_outliers['Amount'].clip(lower=lower_bound, upper=upper_bound)

print(" Outliers handled using IQR capping method")

#  Task 4: Normalization 
numerical_cols = ['Amount', 'Boxes Shipped']

# Min-Max Normalization (0 to 1)
minmax_scaler = MinMaxScaler()
df_minmax = df_no_outliers.copy()
df_minmax[numerical_cols] = minmax_scaler.fit_transform(df_no_outliers[numerical_cols])

# Z-score Normalization
z_scaler = StandardScaler()
df_zscore = df_no_outliers.copy()
df_zscore[numerical_cols] = z_scaler.fit_transform(df_no_outliers[numerical_cols])

print("\n Normalization completed (Min-Max and Z-score)")

#  Task 5: PCA 
correlation = df_no_outliers[numerical_cols].corr()
print("\nCorrelation between Amount and Boxes Shipped:\n", correlation)

# Apply PCA because the two features are highly correlated
pca = PCA(n_components=2)
principal_components = pca.fit_transform(df_no_outliers[numerical_cols])

print(f"\nPCA Explained Variance Ratio: {pca.explained_variance_ratio_}")


plt.figure(figsize=(14, 5))

plt.subplot(1, 3, 1)
plt.scatter(df_no_outliers['Boxes Shipped'], df_no_outliers['Amount'], alpha=0.6)
plt.title('Amount vs Boxes Shipped (After Cleaning)')
plt.xlabel('Boxes Shipped')
plt.ylabel('Amount ($)')

plt.subplot(1, 3, 2)
plt.scatter(principal_components[:,0], principal_components[:,1], alpha=0.6)
plt.title('PCA Projection (2 Components)')
plt.xlabel('Principal Component 1')
plt.ylabel('Principal Component 2')

plt.subplot(1, 3, 3)
sns.boxplot(data=df_no_outliers[['Amount', 'Boxes Shipped']])
plt.title('Boxplot After Outlier Handling')

plt.tight_layout()
plt.show()

print("\n Lab 4 Completed Successfully!")
